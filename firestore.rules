rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return (isSignedIn() && request.auth.uid == userId) || userId.matches('^guest_.*');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- USER VALIDATION BLUEPRINT ---
    function isValidUser(data) {
      return data.uid is string 
        && data.uid.size() <= 128
        && data.displayName is string
        && data.displayName.size() <= 100
        && data.email is string
        && data.email.size() <= 100
        && data.birthYear is number
        && data.createdAt is number
        && data.stats is map
        && data.stats.streaks is number
        && data.stats.completions is number
        && data.activeHabits is list
        && data.activeHabits.size() <= 50
        && (data.get('aiSuggestions', []) is list)
        && (data.get('aiSuggestions', []).size() <= 10);
    }

    // --- MONTHLY HABITS VALIDATION BLUEPRINT ---
    function isValidMonthlyHabits(data) {
      return data.userId is string 
        && data.userId.size() <= 128
        && data.monthId is string
        && data.monthId.size() <= 20
        && data.gridData is map
        && data.updatedAt is number;
    }

    // COLLECTION MATCHES
    
    // 1. Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().uid == userId;

      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && (
          // Action: Update habits
          incoming().diff(existing()).affectedKeys().hasOnly(['activeHabits'])
          // Action: Update stats
          || incoming().diff(existing()).affectedKeys().hasOnly(['stats'])
          // Action: Cache AI suggestions
          || incoming().diff(existing()).affectedKeys().hasOnly(['aiSuggestions'])
          // Action: Full sync
          || incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'birthYear', 'activeHabits', 'stats', 'aiSuggestions'])
        );

      allow delete: if isOwner(userId);

      // 2. Monthly Habits Subcollection
      match /months/{monthId} {
        allow read: if isOwner(userId);
        
        allow create: if isOwner(userId)
          && isValidId(monthId)
          && isValidMonthlyHabits(incoming())
          && incoming().userId == userId
          && incoming().monthId == monthId;

        allow update: if isOwner(userId)
          && isValidMonthlyHabits(incoming())
          && incoming().userId == existing().userId
          && incoming().monthId == existing().monthId
          && (
            // Action: Update grid
            incoming().diff(existing()).affectedKeys().hasOnly(['gridData', 'updatedAt'])
            // Action: Full update
            || incoming().diff(existing()).affectedKeys().hasOnly(['gridData', 'updatedAt', 'userId', 'monthId'])
          );

        allow delete: if isOwner(userId);
      }
    }
  }
}
